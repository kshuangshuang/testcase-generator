# Streamlit Secrets 配置示例
#
# 重要：不要提交真实的 secrets.toml 文件到 Git！
#
# 使用方法：
# 1. 复制此文件为 secrets.toml
# 2. 填入你的真实 API Key
# 3. 确保 secrets.toml 已添加到 .gitignore
#
# 本地开发：
# 将此文件重命名为 secrets.toml 并填入真实值
#
# Streamlit Cloud 部署：
# 在应用的 Settings > Secrets 中手动配置环境变量

# Groq API Key
# 在 https://console.groq.com 获取
GROQ_API_KEY = "your_groq_api_key_here"

# 示例格式（不要使用这些值）：
# GROQ_API_KEY = "gsk_1234567890abcdefghijklmnopqrstuvwxyz"
